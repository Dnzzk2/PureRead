{
    "manifest_version": 3,
    "name": "PureRead",
    "version": "0.0.1",
    "description": "强制修改网页字体，以达到理想的阅读效果。",
    "permissions": [
        "storage",
        "activeTab",
        "fontSettings"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "128": "icon.png"
    }
}