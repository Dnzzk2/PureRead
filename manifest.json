{
    "manifest_version": 3,
    "name": "PureRead",
    "version": "1.0.3",
    "description": "提升网页阅读体验：字体替换、排版调节、阅读进度、专注模式",
    "permissions": [
        "storage",
        "activeTab",
        "fontSettings",
        "alarms"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "options.html",
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "commands": {
        "toggle-progress-bar": {
            "description": "切换阅读进度条"
        },
        "toggle-extension": {
            "suggested_key": {
                "default": "Ctrl+Shift+7",
                "mac": "Command+Shift+7"
            },
            "description": "开关当前站点"
        },
        "toggle-focus-mode": {
            "suggested_key": {
                "default": "Ctrl+Shift+8",
                "mac": "Command+Shift+8"
            },
            "description": "切换专注模式"
        },
        "toggle-dark-mode": {
            "suggested_key": {
                "default": "Ctrl+Shift+9",
                "mac": "Command+Shift+9"
            },
            "description": "切换智能暗色模式"
        },
        "toggle-reading-time": {
            "suggested_key": {
                "default": "Ctrl+Shift+0",
                "mac": "Command+Shift+0"
            },
            "description": "切换阅读时间显示"
        }
    },
    "icons": {
        "128": "icon.png"
    }
}
